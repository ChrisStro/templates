PUBLIC_HOSTNAME=infisical.127.0.0.1.sslip.io
PROXY_NETWORK=traefik_proxy
TRAEFIK_ENTRYPOINTS=websecure

# Image tags (optional)
INFISICAL_IMAGE_TAG=latest
POSTGRES_IMAGE_TAG=14-alpine
REDIS_IMAGE_TAG=7-alpine

# Core
AUTH_SECRET=CHANGEME_THIS_TO_A_RANDOM_STRING
ENCRYPTION_KEY=CHANGEME_THIS_TO_A_RANDOM_STRING

# PostgreSQL
POSTGRES_DB=infisical
POSTGRES_USER=infisical
POSTGRES_PASSWORD=infisical
DB_CONNECTION_URI=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# Redis
REDIS_URL=redis://redis:6379

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
EMAIL_DOMAIN_DENYLIST=

# Website URL
# Required
SITE_URL=https://$PUBLIC_HOSTNAME
